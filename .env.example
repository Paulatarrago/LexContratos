# Autenticacion y licencias
AUTH_PROVIDER=
APP_BASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_STORAGE_BUCKET=contract-documents
SUPABASE_SERVICE_ROLE_KEY=

# Extraccion documental con IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Email transaccional futuro
RESEND_API_KEY=
RESEND_FROM=LexContratos <no-reply@lexcontratos.com>
RESEND_REPLY_TO=contacto@lexcontratos.com
CONTACT_TO=contacto@lexcontratos.com
SUPPORT_EMAIL=soporte@lexcontratos.com

# Pagos/licencias futuras
PAYMENTS_PROVIDER=
LICENSE_WEBHOOK_SECRET=

# Respaldos externos a AWS S3 o bucket compatible.
# Se usan en scripts/backup-supabase-to-s3.mjs, no en el navegador.
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_PREFIX=lexcontratos
# Opcional para proveedores compatibles con S3 como Cloudflare R2, MinIO o storage interno.
BACKUP_S3_ENDPOINT=
BACKUP_S3_FORCE_PATH_STYLE=false
BACKUP_SUPABASE_STORAGE_BUCKET=contract-documents
BACKUP_MAX_STORAGE_BYTES=21474836480
